{
  "name": "react-redux-loading-bar",
  "version": "6.0.0",
  "description": "Simple Loading Bar for Redux and React",
  "type": "module",
  "main": "build/index.cjs",
  "module": "build/index.js",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "types": "index.d.ts",
  "scripts": {
    "build": "node esbuild.config.js",
    "test": "node --import ./jsx-loader.js --test spec/*.js"
  },
  "repository": {
    "type": "git",
    "url": "mironov/react-redux-loading-bar"
  },
  "keywords": [
    "react",
    "redux",
    "loading",
    "loading-bar",
    "progress",
    "progress-bar",
    "react-component"
  ],
  "author": "Anton Mironov (npmjs@mail.mironov.live)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mironov/react-redux-loading-bar/issues"
  },
  "homepage": "https://github.com/mironov/react-redux-loading-bar",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-redux": "^9.0.0",
    "redux": "^5.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^29.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1"
  }
}
