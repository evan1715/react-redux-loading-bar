{
    "name": "react-redux-loading-bar",
    "version": "6.0.0",
    "description": "A React component that provides a Loading Bar for long running tasks, backed by Redux.",
    "type": "module",
    "main": "build/index.cjs",
    "module": "build/index.js",
    "exports": {
        ".": {
            "import": "./build/index.js",
            "require": "./build/index.cjs"
        }
    },
    "types": "index.d.ts",
    "scripts": {
        "build": "node esbuild.config.js",
        "test": "node --import ./jsx-loader.js --test spec/*.js"
    },
    "license": "MIT",
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-redux": "^9.0.0",
        "redux": "^5.0.0"
    },
    "devDependencies": {
        "esbuild": "^0.28.0",
        "jsdom": "^29.0.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-redux": "^9.2.0",
        "redux": "^5.0.1"
    }
}
